{
  "name": "archiplayer",
  "version": "0.3.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:windows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \". .\\build-env.ps1; npm run tauri dev\"",
    "build:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-windows.ps1",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run test:player && npm run test:episode-scroll && npm run test:random-show",
    "test:player": "node --experimental-strip-types tests/playback-transition.test.mjs",
    "test:episode-scroll": "node --experimental-strip-types tests/episode-scroll.test.mjs",
    "test:random-show": "node --experimental-strip-types tests/random-show.test.mjs",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
